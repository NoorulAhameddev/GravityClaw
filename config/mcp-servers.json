{
  "$schema": "../mcp-servers.schema.json",
  "mcpServers": {
    "notion": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_ACCESS_TOKEN": "${NOTION_ACCESS_TOKEN}"
      },
      "disabled": true
    },
    "playwright": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "env": {},
      "disabled": false
    },
    "browser-use": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "browser-use-mcp-server"
      ],
      "env": {},
      "disabled": true
    },
    "puppeteer": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "puppeteer-mcp"
      ],
      "env": {},
      "disabled": true
    },
    "firecrawl": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@mendable/firecrawl-mcp-server"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "disabled": true
    }
  }
}