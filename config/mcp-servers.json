{
  "$schema": "../mcp-servers.schema.json",
  "mcpServers": {
    "notion": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_ACCESS_TOKEN": "${NOTION_ACCESS_TOKEN}"
      },
      "disabled": false
    },
    "playwright": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "env": {},
      "disabled": false
    }
  }
}