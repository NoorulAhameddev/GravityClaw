# ── Telegram ──
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal Telegram user ID (numeric). Get it via @userinfobot
TELEGRAM_ALLOWED_USER_ID=

# ── WhatsApp ──
WHATSAPP_ENABLED=false

# ── LLM Configuration ──
# LLM_PROVIDER: "openrouter" | "anthropic" | "openai" | "google" | "groq" | "ollama" | "failover"
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/free
# Comma-separated list for failover mode (e.g., "openai,anthropic,groq")
LLM_FAILOVER_LIST="openai,anthropic,openrouter"

# ── API Keys ──
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# ── Proactive & Recap ──
# Hour of day (0-23) for daily recap
RECAP_HOUR_LOCAL=20
# Cron for daily recommendations (default: 9 AM)
RECOMMENDATIONS_DAILY_CRON="0 9 * * *"

# ── Voice & Speech (optional) ──
# OpenAI API Key also used for Whisper transcription
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=bella

# ── Desktop/Local Features (optional) ──
WAKE_WORD_ENABLED=false
WAKE_WORD_PHRASE="hey claw"
OLLAMA_BASE_URL="http://localhost:11434"

# ── Security & Privacy ──
# Master key for secrets.enc.json protection
MASTER_KEY=
# Comma-separated list of safe directories for agent disk access
PATH_ALLOWLIST=
# Enable air-gapped mode (requires Ollama running)
AIR_GAPPED=false

# ── Web Search ──
# SEARCH_PROVIDER: "duckduckgo" (free) | "serpapi" | "brave"
SEARCH_PROVIDER=duckduckgo
SERPAPI_API_KEY=
BRAVE_SEARCH_KEY=

# ── System Settings ──
AGENT_MAX_ITERATIONS=10
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
PORT=3000
