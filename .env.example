# =============================================================================
# Gravity Claw Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# Required variables must be set for the application to start.
# Optional variables can be left empty to skip that feature.
# =============================================================================

# ============================================================================
# REQUIRED - Telegram Configuration
# ============================================================================
# Get bot token from @BotFather on Telegram (https://t.me/BotFather)
# This is required to run the bot.
TELEGRAM_BOT_TOKEN=

# Get your user ID from @userinfobot on Telegram (https://t.me/userinfobot)
# Only messages from this user ID will be processed in private chats.
TELEGRAM_ALLOWED_USER_ID=

# ============================================================================
# LLM Provider & Model Configuration
# ============================================================================
# Options: openrouter, anthropic, openai, google, groq, deepseek, ollama, cohere, mistral, nvidia, failover, opencodezen
# Default: openrouter (free tier available)
LLM_PROVIDER=openrouter

# Model name to use (e.g., 'openrouter/free', 'claude-3-sonnet', 'gpt-4o', etc.)
# Consult your LLM provider's documentation for available models.
LLM_MODEL=openrouter/free

# Comma-separated list of providers for failover mode (backup providers if primary fails)
# Example: openai,anthropic,openrouter
LLM_FAILOVER_LIST=openai,anthropic,openrouter

# ============================================================================
# LLM API Keys (at least one required based on LLM_PROVIDER)
# ============================================================================
# OpenRouter - free and paid models (https://openrouter.ai/settings)
# Recommended for getting started; many models on free tier.
OPENROUTER_API_KEY=

# OpenAI - GPT-4 and other models (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# OpenCodeZen - AI gateway service (https://opencode.ai)
# MiniMax 2.5 and other code-optimized models.
OPENCODEZEN_API_KEY=
OPENCODEZEN_BASE_URL=https://opencode.ai/zen/v1

# Anthropic - Claude models (https://console.anthropic.com/keys)
ANTHROPIC_API_KEY=

# Google - Gemini models (https://console.cloud.google.com/apis/credentials)
GOOGLE_API_KEY=

# Groq - Fast inference (https://console.groq.com/keys)
GROQ_API_KEY=

# DeepSeek - Chinese LLM provider (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=

# Cohere - Text generation (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=

# Mistral - Open-source models (https://dashboard.mistral.ai/api-keys)
MISTRAL_API_KEY=

# NVIDIA - NGC models (https://org.ngc.nvidia.com)
NVIDIA_API_KEY=

# ============================================================================
# Embedding & Vector Search (Optional)
# ============================================================================
# Supabase for cloud-based memory and vector storage (optional)
SUPABASE_URL=
SUPABASE_KEY=

# Embedding model for semantic search (default: text-embedding-3-small)
# Used for vector memory operations.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB server URL for local vector memory (leave empty to disable)
# Example: http://localhost:8000
CHROMA_URL=

# ============================================================================
# Voice & Audio (Optional)
# ============================================================================
# ElevenLabs API key for text-to-speech (https://elevenlabs.io/api)
ELEVENLABS_API_KEY=

# ElevenLabs voice ID (default: bella)
# Options: bella, eric, essie, isabella, james, jessica, josh, kunka, lah, michael, rachel, samantha, sarah, william
ELEVENLABS_VOICE_ID=bella

# ============================================================================
# Local Model Support (Optional)
# ============================================================================
# Ollama base URL for running local models offline
# Example: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Wake Word Detection (Optional - Desktop only)
# ============================================================================
# Enable wake word detection (requires microphone access and local processing)
WAKE_WORD_ENABLED=false

# Custom wake phrase for voice activation (default: 'hey claw')
WAKE_WORD_PHRASE=hey claw

# Confidence threshold for wake word detection (0-1, default: 0.75)
WAKE_WORD_THRESHOLD=0.75

# ============================================================================
# Security & Encryption
# ============================================================================
# Master encryption key for secrets.enc.json
# Generate with: npm run secret:generate
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Keep this secret in production!
MASTER_KEY=

# API key for securing HTTP endpoints (required for production)
# Generate with: openssl rand -hex 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Keep this secret in production!
API_KEY=

# Days before secrets are flagged for rotation (default: 90)
SECRET_ROTATION_DAYS=90

# Days to keep deleted secrets before cleanup (default: 90)
SECRET_CLEANUP_DAYS=90

# Comma-separated list of allowed directories for file operations
# (default: workspace root only for security)
SAFE_DIRECTORIES=.

# Enable security audit logging for file access
SECURITY_AUDIT_ENABLED=true

# ============================================================================
# Communication Channels (Optional - enable only what you need)
# ============================================================================

# --- Discord ---
# Discord bot token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Discord guild ID for slash command registration (optional)
DISCORD_GUILD_ID=

# --- Slack ---
# Slack bot token (https://api.slack.com/apps)
SLACK_BOT_TOKEN=

# Slack signing secret (https://api.slack.com/apps)
SLACK_SIGNING_SECRET=

# Slack app ID (optional)
SLACK_APP_ID=

# --- Signal ---
# Your Signal phone number (e.g., +1234567890)
# Leave empty to disable Signal channel
SIGNAL_PHONE_NUMBER=

# Comma-separated Signal group IDs (leave empty to allow all groups)
SIGNAL_GROUP_IDS=

# Comma-separated Signal phone numbers for private messages (leave empty to allow all)
SIGNAL_RECIPIENTS=

# --- WhatsApp ---
# Enable WhatsApp channel (requires Baileys setup)
WHATSAPP_ENABLED=false

# --- Email ---
# SMTP server for sending emails (e.g., smtp.gmail.com)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# IMAP server for receiving emails (e.g., imap.gmail.com)
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=

# Email address to send from
EMAIL_FROM_ADDRESS=

# Comma-separated list of allowed sender email addresses
# (only these senders will be processed by the bot)
EMAIL_ALLOWED_SENDERS=

# ============================================================================
# Google Services (Optional)
# ============================================================================
# Google Calendar API key (https://console.cloud.google.com/apis/credentials)
GOOGLE_CALENDAR_API_KEY=

# Path to Google service account or OAuth2 credentials JSON file
GOOGLE_CREDENTIALS_PATH=

# ============================================================================
# Notion Integration (Optional)
# ============================================================================
# Notion API key (https://www.notion.so/my-integrations)
NOTION_API_KEY=

# Notion database ID to store memories and data
NOTION_DATABASE_ID=

# ============================================================================
# Agent & Loop Configuration
# ============================================================================
# Maximum iterations per agent request (prevents infinite loops)
AGENT_MAX_ITERATIONS=10

# Maximum tool calls per iteration (prevents resource exhaustion)
AGENT_MAX_TOOLS_PER_ITERATION=5

# Maximum total tool calls per agent run
AGENT_MAX_TOOLS_TOTAL=50

# Planning mode: off | auto | force
# auto = plan for long messages; off = never plan; force = always plan
PLANNING_MODE=auto

# Message length threshold to trigger automatic planning (default: 200 chars)
PLANNING_MESSAGE_LENGTH_THRESHOLD=200

# Maximum memories to retrieve per session (default: 8)
RETRIEVAL_MEMORY_LIMIT=8

# Maximum characters for retrieved memories (default: 1800)
RETRIEVAL_MEMORY_MAX_CHARS=1800

# ============================================================================
# Human-in-the-Loop Approval (Optional)
# ============================================================================
# Enable approval middleware for dangerous tools
APPROVAL_ENABLED=true

# Timeout in minutes for approval requests (default: 5)
APPROVAL_TIMEOUT_MINUTES=5

# Comma-separated list of tools requiring human approval
# Examples: run_shell, file_delete, http_request, execute_code
APPROVAL_REQUIRED_TOOLS=run_shell,file_delete,http_request,execute_code

# ============================================================================
# Search Configuration (Optional)
# ============================================================================
# Search provider: duckduckgo | serpapi | brave
# (duckduckgo is free but has no API key requirement)
SEARCH_PROVIDER=duckduckgo

# SerpAPI key for Google search (https://serpapi.com/)
SERPAPI_API_KEY=

# Brave Search API key (https://brave.com/search/api/)
BRAVE_SEARCH_KEY=

# Search results cache TTL in minutes (default: 60)
SEARCH_CACHE_TTL_MINUTES=60

# ============================================================================
# Server & Logging
# ============================================================================
# HTTP server port (default: 3000)
PORT=3000

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Log format: text | json (default: text)
LOG_FORMAT=text

# Enable caller function/file info in logs
ENABLE_CALLER_INFO=false

# ============================================================================
# Observability & Metrics (Optional)
# ============================================================================
# Enable performance metrics collection
ENABLE_METRICS=false

# Enable metrics persistence to database
ENABLE_METRICS_PERSISTENCE=false

# Metrics retention period in hours (default: 24)
METRICS_RETENTION_HOURS=24

# HTTP header name for correlation IDs (for tracing)
CORRELATION_ID_HEADER=x-correlation-id

# Enable distributed tracing
ENABLE_TRACING=false

# Enable OpenTelemetry (https://opentelemetry.io/)
OTEL_ENABLED=false

# OpenTelemetry OTLP exporter endpoint
# Example: http://localhost:4317 (gRPC) or http://localhost:4318/v1/traces (HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT=

# File access log retention in days (default: 90)
FILE_ACCESS_LOG_RETENTION_DAYS=90

# ============================================================================
# Air-Gapped Mode (Optional - Offline/Private)
# ============================================================================
# Enable air-gapped mode (requires Ollama for local models)
# When enabled, no external API calls are made.
AIR_GAPPED=false

# ============================================================================
# Background Task Queue (Optional)
# ============================================================================
# Enable background task processing queue
QUEUE_ENABLED=false

# Redis URL for queue backend
# Example: redis://localhost:6379
REDIS_URL=

# Queue worker concurrency (number of parallel tasks)
QUEUE_CONCURRENCY=5

# ============================================================================
# Scheduled Features (Optional)
# ============================================================================
# Hour of day for daily recap (0-23, default: 20 / 8 PM)
RECAP_HOUR_LOCAL=20

# Cron expression for daily recommendations (default: 9 AM daily)
# Format: minute hour day-of-month month day-of-week
RECOMMENDATIONS_DAILY_CRON=0 9 * * *

# ============================================================================
# Webhook Configuration (Optional)
# ============================================================================
# Base URL for webhook endpoints
# Example: https://example.com for production, or http://localhost:3000 for local
WEBHOOK_BASE_URL=