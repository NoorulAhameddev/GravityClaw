# =============================================================================
# Gravity Claw — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Only the bare minimum variables are required for basic operation.
# Optional variables can be left empty to skip that feature.
#
# See docs/environment.md for detailed descriptions of every variable.

# === REQUIRED (minimum for basic operation) ===
API_KEY=your-api-key-min-32-chars!!!!!!!!!
LLM_PROVIDER=openrouter

# === LLM PROVIDER API KEYS (pick at least one matching LLM_PROVIDER) ===
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=gsk_...
# DEEPSEEK_API_KEY=sk-...
# COHERE_API_KEY=...
# MISTRAL_API_KEY=...
# NVIDIA_API_KEY=...
# OPENCODEZEN_API_KEY=...

# === LLM CONFIGURATION ===
# LLM_MODEL=openrouter/free
# LLM_FAILOVER_LIST=openai,anthropic,openrouter
# LLM_MAX_TOKENS=4096
# LLM_CACHE_ENABLED=false
# OLLAMA_BASE_URL=http://localhost:11434

# === TELEGRAM ===
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_ALLOWED_USER_ID=...

# === DISCORD ===
# DISCORD_BOT_TOKEN=...
# DISCORD_GUILD_ID=...

# === SLACK ===
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_APP_ID=...

# === WHATSAPP ===
# WHATSAPP_ENABLED=false

# === SIGNAL ===
# SIGNAL_PHONE_NUMBER=+1234567890
# SIGNAL_GROUP_IDS=...
# SIGNAL_RECIPIENTS=...

# === EMAIL ===
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=user@gmail.com
# EMAIL_SMTP_PASS=...
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=user@gmail.com
# EMAIL_IMAP_PASS=...
# EMAIL_FROM_ADDRESS=agent@gmail.com
# EMAIL_ALLOWED_SENDERS=...

# === DATABASE ===
# SQLite is default. For PostgreSQL:
# PG_ENABLED=false
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=gravityclaw
# PG_USER=postgres
# PG_PASSWORD=...
# PG_CONNECTION_STRING=postgres://user:pass@localhost:5432/gravityclaw
# PG_POOL_SIZE=10

# === PRODUCTIVITY INTEGRATIONS ===
# GOOGLE_CALENDAR_API_KEY=...
# GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json
# NOTION_API_KEY=secret_...
# NOTION_DATABASE_ID=...

# === SEARCH ===
# SEARCH_PROVIDER=duckduckgo
# BRAVE_SEARCH_KEY=...
# SERPAPI_API_KEY=...
# SEARCH_CACHE_TTL_MINUTES=60

# === VOICE ===
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=bella

# === WAKE WORD (desktop only) ===
# WAKE_WORD_ENABLED=false
# WAKE_WORD_PHRASE=hey claw
# WAKE_WORD_THRESHOLD=0.75

# === MEMORY & KNOWLEDGE ===
# SUPABASE_URL=...
# SUPABASE_KEY=...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# CHROMA_URL=http://localhost:8000
# ENABLE_MEMORY_EXTRACTION=true
# MEMORY_EXTRACTION_MIN_TURNS=3
# MEMORY_DIRECTORY_ENABLED=true
# MEMORY_DIRECTORY_PATH=./memory
# RETRIEVAL_MEMORY_LIMIT=8
# RETRIEVAL_MEMORY_MAX_CHARS=1800

# === AGENT LIMITS ===
# AGENT_MAX_ITERATIONS=10
# AGENT_MAX_TOOLS_PER_ITERATION=5
# AGENT_MAX_TOOLS_TOTAL=50
# AGENT_TOOL_TIMEOUT_MS=60000
# AGENT_MAX_CONCURRENT=10

# === TOKEN & COST MANAGEMENT ===
# TOKEN_BUDGET_ENABLED=false
# TOKEN_BUDGET_MAX=200000
# TOKEN_BUDGET_DIMINISHING_THRESHOLD=500
# LLM_DAILY_CREDIT_LIMIT=10.00
# LLM_DAILY_TOKEN_LIMIT=100000
# LLM_COST_LIMIT_PER_SESSION=10.00

# === AUTO-DREAM (background consolidation) ===
# AUTO_DREAM_ENABLED=false
# AUTO_DREAM_MIN_HOURS=24
# AUTO_DREAM_MIN_SESSIONS=5

# === MICROCOMPACT (context pruning) ===
# ENABLE_MICROCOMPACT=true
# MICROCOMPACT_MAX_TOOL_RESULT_CHARS=10000
# MICROCOMPACT_MAX_TOOLS=3

# === RETRY CONFIGURATION ===
# RETRY_MAX_RETRIES=3
# RETRY_MAX_DELAY_MS=32000
# RETRY_ENABLE_EXPONENTIAL_BACKOFF=true

# === AUTHENTICATION & SECURITY ===
# MASTER_KEY=...
# AIR_GAPPED=false
# SECRET_ROTATION_DAYS=90
# SECRET_CLEANUP_DAYS=90
# SAFE_DIRECTORIES=.
# PATH_ALLOWLIST=...
# SECURITY_AUDIT_ENABLED=true
# UNRESTRICTED_ACCESS=false
# HEALTH_API_KEY=...
# HEALTH_REQUIRE_AUTH=false
# APPROVAL_ENABLED=true
# APPROVAL_TIMEOUT_MINUTES=5
# APPROVAL_REQUIRED_TOOLS=run_shell,file_delete,http_request,execute_code
# AUTH_TRUSTED_CIDRS=...
# AUTH_ALLOW_LOCALHOST=false
# FILE_ACCESS_LOG_RETENTION_DAYS=90

# === SSO / AUTH ===
# SAML_ENABLED=false
# SAML_ENTRY_POINT=...
# SAML_ISSUER=...
# SAML_CALLBACK_URL=...
# SAML_CERT=...
# OIDC_ENABLED=false
# OIDC_ISSUER=...
# OIDC_CLIENT_ID=...
# OIDC_CLIENT_SECRET=...
# OIDC_CALLBACK_URL=...

# === PROACTIVE FEATURES ===
# RECAP_HOUR_LOCAL=20
# RECOMMENDATIONS_DAILY_CRON=0 9 * * *

# === PLANNING ===
# PLANNING_MODE=auto
# PLANNING_MESSAGE_LENGTH_THRESHOLD=200

# === QUEUE ===
# QUEUE_ENABLED=false
# REDIS_URL=...
# QUEUE_CONCURRENCY=5

# === BACKUP ===
# BACKUP_ENABLED=true
# BACKUP_DIR=backups
# BACKUP_CRON=0 2 * * *
# BACKUP_RETENTION_DAYS=30
# BACKUP_ENCRYPT=true
# BACKUP_COMPRESS=true
# BACKUP_MASTER_KEY=...

# === OBSERVABILITY & MONITORING ===
# SENTRY_DSN=...
# LOG_LEVEL=info
# LOG_FORMAT=text
# ENABLE_CALLER_INFO=false
# ENABLE_METRICS=false
# ENABLE_METRICS_PERSISTENCE=false
# METRICS_RETENTION_HOURS=24
# ENABLE_TRACING=false
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=...
# CORRELATION_ID_HEADER=x-correlation-id

# === SERVER ===
# PORT=3000
# NODE_ENV=development
# WEBHOOK_BASE_URL=...

# === OTHER ===
# VITEST=...
# OPENCODEZEN_BASE_URL=https://opencode.ai/zen/v1
