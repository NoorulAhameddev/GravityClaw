# =============================================================================
# Gravity Claw — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Only REQUIRED variables need to be set for basic operation.
# Optional variables can be left empty to skip that feature.

# === REQUIRED (at minimum) ===
API_KEY=your-api-key-min-32-chars!!!!!!!!!
LLM_PROVIDER=openrouter

# === LLM PROVIDER (pick at least one API key) ===
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=gsk_...
# DEEPSEEK_API_KEY=sk-...

# === OPTIONAL INTEGRATIONS ===
# Telegram — set TELEGRAM_ENABLED=true and bot token to enable
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_ALLOWED_USER_ID=...

# Database — defaults to SQLite. Set DATABASE_URL for PostgreSQL
# DATABASE_URL=postgres://user:pass@localhost:5432/gravityclaw

# Voice
# ELEVENLABS_API_KEY=...
# WAKE_WORD_ENABLED=false

# Search
# SEARCH_PROVIDER=brave
# BRAVE_SEARCH_KEY=...

# === ADVANCED (see docs/configuration.md for full list) ===
# PORT=3000
# LOG_LEVEL=info
# MASTER_KEY=...
# SENTRY_DSN=...
