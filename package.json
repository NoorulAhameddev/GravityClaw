{
  "name": "gravyclaw",
  "version": "0.1.0",
  "description": "Gravity Claw — a lean, secure personal AI agent",
  "keywords": [
    "ai-agent",
    "personal-assistant",
    "telegram-bot",
    "whatsapp",
    "mcp",
    "automation",
    "multi-agent",
    "agent-swarms",
    "typescript",
    "llm",
    "openai",
    "anthropic",
    "voice-agent"
  ],
  "author": "Noorul Ahamed",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noorulahamed/gravityclaw.git"
  },
  "homepage": "https://github.com/noorulahamed/gravityclaw#readme",
  "bugs": {
    "url": "https://github.com/noorulahamed/gravityclaw/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "type": "module",
  "bin": {
    "gravityclaw": "./bin/gravityclaw.mjs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config config/vitest.config.ts",
    "test:ui": "vitest --ui --config config/vitest.config.ts",
    "test:run": "vitest run --config config/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/vitest.config.ts",
    "test:performance": "vitest run --config config/vitest.config.ts src/__tests__/performance.test.ts",
    "bench:load": "npx tsx scripts/load-test.ts --clients 50 --messages 100 --duration 60",
    "bench:stress": "npx tsx scripts/stress-test.ts --initial 10 --increment 10 --max-clients 300",
    "bench:tools": "npx tsx scripts/bench-tools.ts",
    "bench:all": "npm run bench:load && npm run bench:stress && npm run bench:tools",
    "secret:generate": "npx tsx scripts/secret-manager.ts generate-key",
    "secret:list": "npx tsx scripts/secret-manager.ts list",
    "secret:add": "npx tsx scripts/secret-manager.ts add-secret",
    "secret:delete": "npx tsx scripts/secret-manager.ts delete-secret",
    "secret:audit": "npx tsx scripts/secret-manager.ts audit",
    "secret:rotate": "npx tsx scripts/secret-manager.ts rotate",
    "secret:cleanup": "npx tsx scripts/secret-manager.ts cleanup",
    "secret:export": "npx tsx scripts/secret-manager.ts export",
    "secret:import": "npx tsx scripts/secret-manager.ts import"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.98.0",
    "@tensorflow-models/speech-commands": "^0.5.4",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "commander": "^11.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "elevenlabs": "^1.59.0",
    "express": "^5.2.1",
    "grammy": "^1.31.0",
    "groq-sdk": "^0.37.0",
    "node-cron": "^4.2.1",
    "node-record-lpcm16": "^1.0.1",
    "openai": "^4.104.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "playwright": "^1.58.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
