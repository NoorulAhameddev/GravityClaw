{
  "name": "gravityclaw",
  "version": "0.1.0",
  "description": "Gravity Claw — a lean, secure personal AI agent",
  "keywords": [
    "ai-agent",
    "personal-assistant",
    "telegram-bot",
    "whatsapp",
    "mcp",
    "automation",
    "multi-agent",
    "agent-swarms",
    "typescript",
    "llm",
    "openai",
    "anthropic",
    "voice-agent"
  ],
  "author": "Noorul Ahamed",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noorulahamed/gravityclaw.git"
  },
  "homepage": "https://github.com/noorulahamed/gravityclaw#readme",
  "bugs": {
    "url": "https://github.com/noorulahamed/gravityclaw/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "type": "module",
  "bin": {
    "gravityclaw": "./bin/gravityclaw.mjs"
  },
  "scripts": {
    "build": "npx esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outdir=dist --packages=external",
    "dev": "npx tsx watch --exclude gravity.db* --exclude logs/**/* src/index.ts",
    "start": "node --max-old-space-size=512 dist/index.js",
    "cli": "npx tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config config/vitest.config.ts",
    "test:ui": "vitest --ui --config config/vitest.config.ts",
    "test:run": "vitest run --config config/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/vitest.config.ts",
    "test:performance": "vitest run --config config/vitest.config.ts src/__tests__/performance.test.ts",
    "bench:load": "npx tsx scripts/load-test.ts --clients 50 --messages 100 --duration 60",
    "bench:stress": "npx tsx scripts/stress-test.ts --initial 10 --increment 10 --max-clients 300",
    "bench:tools": "npx tsx scripts/bench-tools.ts",
    "bench:all": "npm run bench:load && npm run bench:stress && npm run bench:tools",
    "secret:generate": "npx tsx scripts/secret-manager.ts generate-key",
    "secret:list": "npx tsx scripts/secret-manager.ts list",
    "secret:add": "npx tsx scripts/secret-manager.ts add-secret",
    "secret:delete": "npx tsx scripts/secret-manager.ts delete-secret",
    "secret:audit": "npx tsx scripts/secret-manager.ts audit",
    "secret:rotate": "npx tsx scripts/secret-manager.ts rotate",
    "secret:cleanup": "npx tsx scripts/secret-manager.ts cleanup",
    "secret:export": "npx tsx scripts/secret-manager.ts export",
    "secret:import": "npx tsx scripts/secret-manager.ts import",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "@googleapis/calendar": "^14.2.0",
    "@mistralai/mistralai": "^1.15.1",
    "@notionhq/client": "^5.13.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/instrumentation": "^0.57.0",
    "@opentelemetry/instrumentation-express": "^0.45.0",
    "@opentelemetry/instrumentation-http": "^0.57.0",
    "@opentelemetry/resources": "^1.27.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/sdk-trace-base": "^1.27.0",
    "@opentelemetry/sdk-trace-node": "^1.27.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@slack/events-api": "^3.0.1",
    "@slack/web-api": "^7.15.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tensorflow-models/speech-commands": "^0.5.4",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "ajv": "^8.18.0",
    "better-sqlite3": "^12.6.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chromadb": "^3.3.1",
    "cli-table3": "^0.6.5",
    "cohere-ai": "^7.20.0",
    "commander": "^11.1.0",
    "cors": "^2.8.6",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.7",
    "elevenlabs": "^1.59.0",
    "enquirer": "^2.4.1",
    "express": "^5.2.1",
    "fuse.js": "^7.1.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.31.0",
    "groq-sdk": "^0.37.0",
    "imap": "^0.8.19",
    "lodash": "^4.18.1",
    "multer": "^2.1.1",
    "music-metadata": "^11.12.3",
    "node-cron": "^4.2.1",
    "node-record-lpcm16": "^1.0.1",
    "nodemailer": "^8.0.2",
    "openai": "^4.104.0",
    "ora": "^9.3.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "skillfish": "^1.0.30",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  },
  "overrides": {
    "fast-xml-parser": "^4.4.1",
    "brace-expansion": "^2.0.2"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.68",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/imap": "^0.8.43",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "esbuild": "^0.28.0",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
